#!/bin/sh
# Start an XMonad session under WSLg.
#
# WSLg's Xwayland (display :0) is rootless, so a window manager cannot
# manage it directly. Instead we start a nested Xephyr server, shown as a
# single window on the Windows desktop, and run xmonad inside that.

set -e

if ! command -v Xephyr >/dev/null 2>&1; then
	echo "xmonad-wslg: Xephyr not found on PATH; try: sudo apt install xserver-xephyr" >&2
	exit 1
fi

if [ ! -S /tmp/.X11-unix/X0 ]; then
	echo "xmonad-wslg: host X socket /tmp/.X11-unix/X0 not found; is WSLg running?" >&2
	exit 1
fi

# Under WSLg /tmp/.X11-unix is a read-only tmpfs, so Xephyr cannot create a
# filesystem socket there and only binds the Linux abstract socket
# (@/tmp/.X11-unix/Xn); check both kinds when probing displays.
display_socket_exists() {
	[ -S "/tmp/.X11-unix/X$1" ] ||
		ss -xl 2>/dev/null | grep -q "@/tmp/.X11-unix/X$1[[:space:]]"
}

# Pick the first free nested display number (:1, :2, ...).
display_num=1
while display_socket_exists "$display_num" || [ -e "/tmp/.X$display_num-lock" ]; do
	display_num=$((display_num + 1))
done
nested_display=:$display_num

geometry=${XMONAD_WSLG_GEOMETRY:-1920x1080}

# Xephyr itself is an X client, so it needs DISPLAY pointed at the host
# (WSLg) server; the display number it creates is given as its argument.
DISPLAY=:0 Xephyr "$nested_display" \
	-ac \
	-resizeable \
	-screen "$geometry" \
	-title "xmonad (WSLg)" &
xephyr_pid=$!

cleanup() {
	if [ -n "${fcitx5_pid:-}" ]; then
		kill "$fcitx5_pid" 2>/dev/null || :
	fi
	kill "$xephyr_pid" 2>/dev/null || :
}
trap cleanup EXIT INT TERM

# Wait for the nested display's socket to appear before starting xmonad.
timeout=10
waited=0
until display_socket_exists "$display_num"; do
	if ! kill -0 "$xephyr_pid" 2>/dev/null; then
		echo "xmonad-wslg: Xephyr exited before $nested_display became ready" >&2
		exit 1
	fi
	if [ "$waited" -ge "$timeout" ]; then
		echo "xmonad-wslg: timed out waiting for Xephyr on $nested_display" >&2
		exit 1
	fi
	sleep 1
	waited=$((waited + 1))
done

# Shared environment for every client on the nested display: force X11
# backends (with WSLg's wayland socket present, GTK/Qt/SDL apps would
# otherwise open on the host Wayland compositor instead of the nested
# display; GDK even tries the default "wayland-0" socket when
# WAYLAND_DISPLAY is unset) and route input through fcitx5 for Japanese
# input. Used for both fcitx5 itself and xmonad so the list isn't
# duplicated.
session_env() {
	env -u WAYLAND_DISPLAY \
		DISPLAY="$nested_display" \
		GDK_BACKEND=x11 \
		QT_QPA_PLATFORM=xcb \
		SDL_VIDEODRIVER=x11 \
		XDG_SESSION_TYPE=x11 \
		GTK_IM_MODULE=fcitx \
		QT_IM_MODULE=fcitx \
		XMODIFIERS=@im=fcitx \
		SDL_IM_MODULE=fcitx \
		"$@"
}

# fcitx5 is optional: Japanese input is nice to have but the session must
# still start without it.
if command -v fcitx5 >/dev/null 2>&1; then
	session_env fcitx5 >/dev/null 2>&1 &
	fcitx5_pid=$!
else
	fcitx5_pid=
	echo "xmonad-wslg: fcitx5 not found on PATH; Japanese input disabled (try: sudo apt install fcitx5 fcitx5-mozc)" >&2
fi

custom_bin="$HOME/.xmonad/xmonad-$(uname -m)-linux"
if [ -x "$custom_bin" ]; then
	xmonad_bin="$custom_bin"
elif command -v xmonad >/dev/null 2>&1; then
	xmonad_bin=xmonad
else
	echo "xmonad-wslg: no xmonad binary found ($custom_bin or xmonad on PATH)" >&2
	exit 1
fi

session_env "$xmonad_bin"
