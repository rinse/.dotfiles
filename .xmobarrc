Config
  { font = "xft:UDEV Gothic LG-13"
  , additionalFonts = []
  , borderColor = "black"
  , border = TopB
  , bgColor = "black"
  , fgColor = "grey"
  , position = TopW L 100
, commands =
    [ Run Network "eth0"
        [ "--Low", "10240", "--High","524288"
        , "--normal", "green", "--high","red"
        , "--template", "<dev>: ↓<rx>kB|↑<tx>kB"
        , "-w", "5"
        ] 10
    , Run Swap [] 10
    , Run Com "uname" [ "-s", "-r" ] "" 36000
    , Run Date "%Y/%m/%d(%a) %H:%M:%S" "date" 10
    , Run StdinReader
    , Run Kbd
        [ ("us(dvorak)" , "DV")
        , ("us"         , "US")
        , ("jp"         , "JP")
        , ("ja"         , "JA")
        ]
    ]
  , sepChar = "%"
  , alignSep = "}{"
  , template = "%StdinReader% }{ %eth0% | %kbd% | <fc=#ee9a00>%date%</fc>"
  }
